---
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const isActive = (href: string) => {
	if (href === '/') return pathname === '/';
	return pathname === href || pathname.startsWith(href + '/');
};

const links = [
	{ href: '/', label: 'Home' },
	{ href: '/proyectos', label: 'Projects' },
];
---

<header class="border-b border-neutral-900">
	<nav
		class="mx-auto flex max-w-3xl items-center justify-between px-6 py-5"
	>
		<a
			href="/"
			class="font-mono text-sm text-text-primary hover:text-accent"
		>
			victor<span class="text-accent">.</span>dev
		</a>
		<ul class="flex items-center gap-6 text-sm">
			{
				links.map((link) => (
					<li>
						<a
							href={link.href}
							class:list={[
								'transition-colors hover:text-accent',
								isActive(link.href)
									? 'text-accent'
									: 'text-text-secondary',
							]}
						>
							{link.label}
						</a>
					</li>
				))
			}
		</ul>
	</nav>
</header>
